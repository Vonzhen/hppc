config homeproxy 'infra'
    option __warning 'DO NOT EDIT THIS SECTION, OR YOU ARE ON YOUR OWN!'
    option common_port '22,53,80,143,443,465,853,873,993,995,5222,8080,8443,9418'
    option mixed_port '5330'
    option redirect_port '5331'
    option tproxy_port '5332'
    option dns_port '5333'
    option ntp_server 'time.apple.com'
    option sniff_override '1'
    option tun_name 'singtun0'
    option tun_addr4 '172.19.0.1/30'
    option tun_addr6 'fdfe:dcba:9876::1/126'
    option tun_mtu '9000'
    option table_mark '100'
    option self_mark '100'
    option tproxy_mark '101'
    option tun_mark '102'

config homeproxy 'migration'
    option crontab '1'

config homeproxy 'config'
    option routing_mode 'custom'
    option proxy_mode 'redirect_tproxy'
    option ipv6_support '1'
    option log_level 'warn'
    option clash_api_port '9090'
    option clash_api_host '0.0.0.0'

config homeproxy 'control'
    option lan_proxy_mode 'disabled'
    list wan_proxy_ipv4_ips '91.105.192.0/23'
    list wan_proxy_ipv4_ips '91.108.4.0/22'
    list wan_proxy_ipv4_ips '91.108.8.0/22'
    list wan_proxy_ipv4_ips '91.108.16.0/22'
    list wan_proxy_ipv4_ips '91.108.12.0/22'
    list wan_proxy_ipv4_ips '91.108.20.0/22'
    list wan_proxy_ipv4_ips '91.108.56.0/22'
    list wan_proxy_ipv4_ips '149.154.160.0/20'
    list wan_proxy_ipv4_ips '185.76.151.0/24'
    list wan_proxy_ipv4_ips '203.208.50.66/32'
    list wan_proxy_ipv6_ips '2001:67c:4e8::/48'
    list wan_proxy_ipv6_ips '2001:b28:f23c::/48'
    list wan_proxy_ipv6_ips '2001:b28:f23d::/48'
    list wan_proxy_ipv6_ips '2001:b28:f23f::/48'
    list wan_proxy_ipv6_ips '2a0a:f280::/32'

config homeproxy 'routing'
    option sniff_override '1'
    option default_outbound 'us04'
    option default_outbound_dns 'paopaodns'
    option bypass_cn_traffic '0'
    option domain_strategy 'prefer_ipv4'

config homeproxy 'dns'
    option dns_strategy 'prefer_ipv4'
    option default_server 'paopaodns'
    option default_strategy 'prefer_ipv4'

config homeproxy 'subscription'
    option auto_update '0'
    option allow_insecure '0'
    option packet_encoding 'xudp'
    option update_via_proxy '0'
    option filter_nodes 'blacklist'
    option user_agent 'homeproxy'
    list filter_keywords '重置|到期|过期|剩余|套餐'
    list filter_keywords 'Expiration|Remaining'
    list filter_keywords '网址'

config homeproxy 'server'
    option enabled '0'
    option log_level 'warn'

config dns_rule 'ADblock'
	option label 'ADblock'
	option enabled '1'
	option mode 'default'
	list rule_set 'geositecategoryadsall'
	option action 'reject'
	option reject_method 'default'

config dns_rule 'LocalDNS'
    option label 'Local'
    option enabled '1'
    option mode 'default'
    option action 'route'
    option server 'paopaodns'
    option domain_strategy 'prefer_ipv4'
    list rule_set 'geositecn'
    list rule_set 'geositeprivatedirect'

config dns_rule 'Apple'
    option label 'Apple'
    option enabled '1'
    option mode 'default'
    list rule_set 'geositeapple'
    option action 'route'
    option server 'cloudflaredns'
    option domain_strategy 'prefer_ipv4'

config dns_rule 'Remot'
    option label 'Proxy'
    option enabled '1'
    option mode 'default'
    option action 'route'
    option server 'paopaodns'
    list rule_set 'geositenoncn'
    option domain_strategy 'prefer_ipv4'

config dns_server 'paopaodns'
    option label 'PaoPaoDNS'
    option enabled '1'
    option type 'udp'
    option server '10.10.10.254'
    option outbound 'direct-out'

config dns_server 'localdns'
    option label 'Local-DNS'
    option enabled '1'
    option type 'https'
    option server '223.5.5.5'
    option outbound 'direct-out'

config dns_server 'remotedns'
    option label 'Remote-DNS'
    option enabled '1'
    option type 'https'
    option server '8.8.8.8'
    option outbound 'hk02'

config dns_server 'cloudflaredns'
    option label 'Cloudflare-DNS'
    option enabled '1'
    option type 'https'
    option server '1.1.1.1'
    option outbound 'hk01'

config routing_rule 'categoryadsall'
    option label 'Category-Ads'
    option enabled '1'
    option mode 'default'
    list rule_set 'geositecategoryadsall'
    option action 'reject'
    option reject_method 'default'

config routing_rule 'apple'
    option label 'Apple'
    option enabled '1'
    option mode 'default'
    list rule_set 'geositeapple'
    list rule_set 'geoipapple'
    option action 'route'
    option outbound 'direct-out'

