config node '{{ID}}'
    option label '{{LABEL}}'
    option type 'vmess'
    option address '{{SERVER}}'
    option port '{{PORT}}'
    option uuid '{{UUID}}'
    option vmess_alterid '{{ALTER_ID}}'
    option vmess_encrypt '{{CIPHER}}'
    option vmess_global_padding '1'
    option transport '{{TRANSPORT}}'
    option tls '{{TLS}}'
    option tls_sni '{{SNI}}'
    option ws_host '{{WS_HOST}}'
    option ws_path '{{WS_PATH}}'
    option packet_encoding 'xudp'
